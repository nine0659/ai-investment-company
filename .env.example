# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini          # 일반 에이전트용 모델
OPENAI_MODEL_CEO=gpt-4o            # CEO 에이전트 전용 (더 정교한 분석, 선택사항)

# ─────────────────────────────────────────
# Telegram Bot
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_ID=123456789

# ─────────────────────────────────────────
# 한국투자증권 (KIS) OpenAPI
# ─────────────────────────────────────────
KIS_APP_KEY=...
KIS_APP_SECRET=...
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PROD_CD=01

# ─────────────────────────────────────────
# DART OpenAPI (중기/장기 재무분석)
# 발급: https://opendart.fss.or.kr
# ─────────────────────────────────────────
DART_API_KEY=...

# ─────────────────────────────────────────
# 웹 대시보드 (선택사항)
# WEB_PASSWORD 설정 시 접속 시 비밀번호 요구
# ─────────────────────────────────────────
# WEB_PASSWORD=your_secret_password

# ─────────────────────────────────────────
# 데이터베이스 (Supabase PostgreSQL)
# 미설정 시 로컬 SQLite 사용
# Supabase: Settings → Database → Connection string → URI 탭
# ─────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
